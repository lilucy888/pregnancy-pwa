# Firebase 配置 - 从 Firebase 控制台复制粘贴
# 文件名：.env（放在项目根目录，和 package.json 同级）
# 注意：.env 不要提交到 GitHub！已在 .gitignore 里屏蔽

VITE_FB_API_KEY=你的apiKey
VITE_FB_AUTH_DOMAIN=你的项目.firebaseapp.com
VITE_FB_PROJECT_ID=你的项目ID
VITE_FB_STORAGE_BUCKET=你的项目.appspot.com
VITE_FB_MESSAGING_SENDER_ID=你的messagingSenderId
VITE_FB_APP_ID=你的appId
